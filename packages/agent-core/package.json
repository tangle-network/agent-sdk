{
  "name": "@tangle-network/agent-core",
  "version": "0.3.6",
  "description": "Core transport interfaces, event utilities, auth, SSE parsing, and resilience primitives for talking to Tangle agents",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    },
    "./transport": {
      "import": "./dist/transport/index.js",
      "types": "./src/transport/index.ts"
    },
    "./events": {
      "import": "./dist/events/index.js",
      "types": "./src/events/index.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./src/types/index.ts"
    },
    "./sse": {
      "import": "./dist/sse/index.js",
      "types": "./src/sse/index.ts"
    },
    "./auth": {
      "import": "./dist/auth/index.js",
      "types": "./src/auth/index.ts"
    },
    "./auth/browser": {
      "import": "./dist/auth/browser.js",
      "types": "./src/auth/browser.ts"
    },
    "./resilience": {
      "import": "./dist/resilience/index.js",
      "types": "./src/resilience/index.ts"
    },
    "./computer-use": {
      "import": "./dist/computer-use/index.js",
      "types": "./src/computer-use/index.ts"
    },
    "./telemetry": {
      "import": "./dist/telemetry/index.js",
      "types": "./src/telemetry/index.ts"
    }
  },
  "typesVersions": {
    "*": {
      "auth": [
        "src/auth/index.ts"
      ],
      "auth/*": [
        "src/auth/*"
      ],
      "auth/browser": [
        "src/auth/browser.ts"
      ],
      "events": [
        "src/events/index.ts"
      ],
      "events/*": [
        "src/events/*"
      ],
      "resilience": [
        "src/resilience/index.ts"
      ],
      "resilience/*": [
        "src/resilience/*"
      ],
      "computer-use": [
        "src/computer-use/index.ts"
      ],
      "computer-use/*": [
        "src/computer-use/*"
      ],
      "transport": [
        "src/transport/index.ts"
      ],
      "transport/*": [
        "src/transport/*"
      ],
      "types": [
        "src/types/index.ts"
      ],
      "types/*": [
        "src/types/*"
      ],
      "*": [
        "src/index.ts"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tangle-network/agent-sdk.git",
    "directory": "packages/agent-core"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./transport": {
        "import": "./dist/transport/index.js",
        "types": "./dist/transport/index.d.ts",
        "default": "./dist/transport/index.js"
      },
      "./events": {
        "import": "./dist/events/index.js",
        "types": "./dist/events/index.d.ts",
        "default": "./dist/events/index.js"
      },
      "./types": {
        "import": "./dist/types/index.js",
        "types": "./dist/types/index.d.ts",
        "default": "./dist/types/index.js"
      },
      "./sse": {
        "import": "./dist/sse/index.js",
        "types": "./dist/sse/index.d.ts",
        "default": "./dist/sse/index.js"
      },
      "./auth": {
        "import": "./dist/auth/index.js",
        "types": "./dist/auth/index.d.ts",
        "default": "./dist/auth/index.js"
      },
      "./auth/browser": {
        "import": "./dist/auth/browser.js",
        "types": "./dist/auth/browser.d.ts",
        "default": "./dist/auth/browser.js"
      },
      "./resilience": {
        "import": "./dist/resilience/index.js",
        "types": "./dist/resilience/index.d.ts",
        "default": "./dist/resilience/index.js"
      },
      "./computer-use": {
        "import": "./dist/computer-use/index.js",
        "types": "./dist/computer-use/index.d.ts",
        "default": "./dist/computer-use/index.js"
      },
      "./telemetry": {
        "import": "./dist/telemetry/index.js",
        "types": "./dist/telemetry/index.d.ts",
        "default": "./dist/telemetry/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit",
    "prepare": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tangle-network/agent-interface": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "^6.0.3",
    "vitest": "catalog:"
  }
}
